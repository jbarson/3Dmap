 function startAt0( stime ) {
  state = TRUE;
  tproc.set_startTime = stime;
  tproc.enabled = TRUE;
  pause = 0;
 }
 "
}
DEF Script_Wizard Script {
  field    SFNode      tproc     USE  Wizard
 field    SFBool state     FALSE
 field    SFTime pause     0
 eventIn  SFTime startAt0
 eventOut SFTime triggerStart
 eventOut SFTime triggerStop
 eventOut SFTime triggerStartInt
 eventIn  SFBool activated
 eventIn  SFTime cycle
 directOutput TRUE
 url "vrmlscript:
 function activated( active, curtime ) {
  if( active ) {
   triggerStart = curtime;
   state = TRUE;
  }
  else {
   triggerStop = curtime;
   state = FALSE;
  }
 }
 function cycle( curtime ) {
  triggerStartInt = curtime;
 }
 function startAt0( stime ) {
  state = TRUE;
  tproc.set_startTime = stime;
  tproc.enabled = TRUE;
  pause = 0;
 }
 "
}
DEF spazz_init TimeSensor {
  cycleInterval 0.1
  loop TRUE
}
ROUTE spazz_init.cycleTime TO Script_Wizard0.startAt0
ROUTE spazz_init.cycleTime TO Script_Wizard2.startAt0
